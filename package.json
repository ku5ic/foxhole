{
  "name": "foxhole",
  "version": "1.0.0",
  "description": "Frontend audit CLI and MCP server. Audits URLs and local builds for a11y, performance, semantics, and bundle issues.",
  "type": "module",
  "main": "./dist/cli/index.js",
  "bin": {
    "foxhole": "./bin/foxhole.js"
  },
  "exports": {
    ".": "./dist/cli/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ku5ic/foxhole.git"
  },
  "homepage": "https://github.com/ku5ic/foxhole#readme",
  "bugs": {
    "url": "https://github.com/ku5ic/foxhole/issues"
  },
  "keywords": [
    "accessibility",
    "lighthouse",
    "axe-core",
    "performance",
    "audit",
    "ci",
    "frontend",
    "mcp"
  ],
  "author": "Sinisa Kusic",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli/index.ts",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "release": "changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axe-core": "^4.11.2",
    "commander": "^14.0.3",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "serve-handler": "^6.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/serve-handler": "^6.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
